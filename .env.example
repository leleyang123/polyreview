# PolyReview — LLM Provider Configuration
# Copy this file to .env and fill in your API keys.

# ============================================
# Primary: Anthropic Claude 4 Opus
# Used for: Complex multi-step reasoning, security analysis
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# Secondary: OpenAI ChatGPT 5.4
# Used for: High-throughput tasks, test generation
# ============================================
OPENAI_API_KEY=sk-xxx

# ============================================
# Cost-efficient: DeepSeek V4
# Used for: Style checks, boilerplate detection
# ============================================
DEEPSEEK_API_KEY=sk-xxx

# ============================================
# Multi-modal: Google Gemini 3.1 Pro
# Used for: Architecture diagram analysis, screenshot review
# ============================================
GEMINI_API_KEY=sk-xxx

# ============================================
# 🎯 Target Migration: Xiaomi MiMo V2.5 Pro
# Applying for: Xiaomi MiMo 100T Creator Incentive Program
# URL: https://100t.xiaomimimo.com/
# Plan: Migrate core reasoning engine from Claude 4 Opus → MiMo V2.5 Pro
# Expectation: Validate 1M+ context window multi-step reasoning performance
# Deliverable: Public benchmark comparison + optimized open-source adapter
# ============================================
MIMO_API_KEY=sk-mimo-xxx
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# ============================================
# PolyReview Settings
# ============================================
POLYREVIEW_POOL_SIZE=8
POLYREVIEW_CONFIDENCE_THRESHOLD=0.70
POLYREVIEW_DEEP_SECURITY=true
POLYREVIEW_PATCH_RE_REVIEW=true

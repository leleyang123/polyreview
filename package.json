{
  "name": "polyreview",
  "version": "3.2.1",
  "description": "Multi-Agent Code Review & Automated Refactoring Engine — 48h → 30s",
  "main": "dist/index.js",
  "bin": {
    "polyreview": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "start": "node dist/index.js",
    "serve": "node dist/cli.js serve"
  },
  "keywords": [

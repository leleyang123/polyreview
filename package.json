    "commander": "^12.0.0",
    "openai": "^4.60.0",
    "semgrep": "^1.0.0",
    "simple-git": "^3.25.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.23.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.21.0",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
